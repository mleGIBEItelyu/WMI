# ─────────────────────────────────────────────────────────────────────────────
# Weekly Market Insight — environment configuration (Google Gemini)
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# Only GOOGLE_API_KEY is required; everything else has sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — get a free key at https://aistudio.google.com/apikey
# (GEMINI_API_KEY is accepted as an alias.)
GOOGLE_API_KEY=AIza_xxxxx

# ── Models per agent (overridable so the pipeline survives model renames) ─────
# Default is gemini-2.0-flash: a GA model with a real free tier for new accounts and
# Google Search grounding support. (Newer aliases like gemini-flash-latest can route
# to preview models with no free quota -> 429; pinned gemini-2.5-flash is blocked for
# new users -> 404.) Override per agent if your account has access to a better model.
# WMI_NEWS_MODEL=gemini-2.0-flash
# WMI_QUANT_MODEL=gemini-2.0-flash
# WMI_EDITOR_MODEL=gemini-2.0-flash

# Lighter model used automatically if the news model hits a capacity limit (429).
# Set blank to disable fallback.
# WMI_NEWS_FALLBACK_MODEL=gemini-2.0-flash-lite

# ── Thinking budget (Gemini 2.5 "thinking" tokens) ───────────────────────────
# 0 disables thinking: faster, cheaper, and guarantees the JSON isn't truncated
# by thinking tokens. Raise (e.g. 1024) for deeper reasoning at higher cost.
# WMI_THINKING_BUDGET=0

# ── Token budgets per agent (max output tokens) ──────────────────────────────
# WMI_NEWS_MAX_TOKENS=12000       # generous: broad harvest JSON (with urls) is long
# WMI_QUANT_MAX_TOKENS=4000
# WMI_EDITOR_MAX_TOKENS=2500

# ── Sampling temperature per agent ───────────────────────────────────────────
# WMI_NEWS_TEMPERATURE=0.3
# WMI_QUANT_TEMPERATURE=0.2
# WMI_EDITOR_TEMPERATURE=0.4

# ── Pipeline behaviour ───────────────────────────────────────────────────────
# WMI_MIN_VALID_CANDIDATES=8      # below this, the harvester retries once
# WMI_TARGET_CANDIDATES=20        # how many candidates the harvester aims to gather
# WMI_SHORTLIST_COUNT=10          # top-impact stories whose FULL article is read
# WMI_MIN_ID_SHORTLIST=3          # guaranteed Indonesian stories in the shortlist
# WMI_HIGHLIGHT_COUNT=6           # weekly highlights chosen (diversely) from the shortlist
# WMI_MAX_LOW_HIGHLIGHTS=1        # more low-authority highlights than this -> needs editor review

# ── Source authority (P0-2): extend the built-in trusted / low-authority lists ─
# Comma-separated substrings, matched (case-insensitive) against the source name.
# WMI_SOURCE_TIER1=my trusted outlet,another wire
# WMI_SOURCE_LOW=some seo blog,content farm

# ── Full-article fetching (stage 3: read the shortlisted stories in full) ─────
# WMI_FETCH_TIMEOUT=20            # seconds per article HTTP request
# WMI_FETCH_WORKERS=6            # parallel fetches
# WMI_FETCH_MAX_CHARS=6000       # cap extracted article text (controls editor tokens)
# WMI_FETCH_MIN_CHARS=250        # below this, treat extraction as failed (use snippet)
# WMI_FETCH_USER_AGENT=Mozilla/5.0 ...  # override the request User-Agent
# WMI_REQUEST_TIMEOUT=120         # seconds per API request
# WMI_MAX_RETRIES=4               # tenacity attempts on 429 / transient errors
# WMI_RETRY_MAX_WAIT=60           # cap (seconds) for backoff between retries

# ── Paths (relative to project root unless absolute) ─────────────────────────
# WMI_OUTPUT_DIR=output
# WMI_CACHE_DIR=output
# WMI_PROMPTS_DIR=prompts

# ── Report metadata ──────────────────────────────────────────────────────────
# WMI_SOURCE_DEPARTMENT=Research and Education Department
